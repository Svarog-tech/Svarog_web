# Jednotné konce řádků (LF) v repozitáři i ve working copy na Windows.
# S lokálním `git config core.autocrlf false` zmizí varování „LF will be replaced by CRLF“.
* text=auto eol=lf

# Binární soubory (Git je nemá převádět)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
