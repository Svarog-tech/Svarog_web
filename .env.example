# ===========================================
# Alatyr Hosting - Environment Variables
# Zkopírujte na .env a vyplňte hodnoty
# ===========================================

# Server
NODE_ENV=development
PORT=3001

# CORS - povolené origins (oddělené čárkou)
SERVER_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Frontend base URL (používá se v emailech pro odkazy)
APP_URL=http://localhost:3000

# Frontend API URL (Vite prefix)
VITE_API_URL=http://localhost:3001/api

# MySQL databáze
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=alatyr_hosting
MYSQL_POOL_SIZE=10
MYSQL_SSL=false

# JWT - minimálně 32 znaků!
JWT_SECRET=
REFRESH_TOKEN_SECRET=
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# HestiaCP
HESTIACP_URL=
HESTIACP_USERNAME=admin
HESTIACP_ACCESS_KEY=
HESTIACP_SECRET_KEY=
HESTIACP_SERVER_IP=
HESTIACP_DEFAULT_PACKAGE=default

# GoPay (POUZE server-side – NESMÍ mít prefix REACT_APP_, jinak se kompilují do JS bundlu!)
GOPAY_ENVIRONMENT=SANDBOX
GOPAY_CLIENT_ID=
GOPAY_CLIENT_SECRET=
GOPAY_GO_ID=

# Logging (volitelné)
LOG_LEVEL=debug

# SMTP (pro odesílání emailů – reset hesla, notifikace)
# Pokud není nastaveno, aplikace emaily nebude fyzicky odesílat, ale reset link vypíše do logu.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM="Alatyr Hosting <no-reply@your-domain.cz>"

# OAuth - Google (volitelné, pro přihlášení přes Google)
# Získáte na https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth - GitHub (volitelné, pro přihlášení přes GitHub)
# Získáte na https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Discord notifikace (volitelné, pro notifikace o nových ticketech)
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# Gemini AI (pro AI asistenta na webu)
# Získáte na https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=
