# ===========================================
# Alatyr Hosting - Environment Variables
# Zkopírujte na .env a vyplňte hodnoty
# ===========================================

# Server
NODE_ENV=development
PORT=3001

# CORS - povolené origins (oddělené čárkou)
SERVER_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Frontend API URL
REACT_APP_API_URL=http://localhost:3001/api

# MySQL databáze
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=alatyr_hosting
MYSQL_POOL_SIZE=10
MYSQL_SSL=false

# JWT - minimálně 32 znaků!
JWT_SECRET=
REFRESH_TOKEN_SECRET=
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=30d

# HestiaCP
HESTIACP_URL=
HESTIACP_USERNAME=admin
HESTIACP_ACCESS_KEY=
HESTIACP_SECRET_KEY=
HESTIACP_SERVER_IP=
HESTIACP_DEFAULT_PACKAGE=default

# GoPay
REACT_APP_GOPAY_ENVIRONMENT=SANDBOX
REACT_APP_GOPAY_CLIENT_ID=
REACT_APP_GOPAY_CLIENT_SECRET=
REACT_APP_GOPAY_GO_ID=

# Logging (volitelné)
LOG_LEVEL=debug
