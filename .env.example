# ===========================================
# Alatyr Hosting – příklad konfigurace (.env)
# Zkopírujte na .env a vyplňte hodnoty.
# V produkci nastavte NODE_ENV=production a APP_URL na reálnou doménu.
# ===========================================

NODE_ENV=production
PORT=3001

# Veřejná URL aplikace (e-maily, OAuth callbacky, odkazy v UI)
APP_URL=https://alatyrhosting.eu

# -------------------------------------------
# MySQL
# -------------------------------------------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=alatyr_hosting
MYSQL_POOL_SIZE=10
# MYSQL_SSL=true
# MYSQL_CA_CERT=/path/to/ca.pem

# -------------------------------------------
# JWT (min. 32 znaků pro JWT_SECRET a REFRESH_TOKEN_SECRET)
# -------------------------------------------
JWT_SECRET=
REFRESH_TOKEN_SECRET=
# JWT_EXPIRES_IN=24h
# JWT_REFRESH_EXPIRES_IN=7d

# -------------------------------------------
# HestiaCP API
# -------------------------------------------
HESTIACP_URL=https://panel.example.com:8083
HESTIACP_USERNAME=admin
HESTIACP_ACCESS_KEY=
HESTIACP_SECRET_KEY=
HESTIACP_SERVER_IP=
HESTIACP_DEFAULT_PACKAGE=default

# -------------------------------------------
# CORS – povolené originy (oddělené čárkou)
# -------------------------------------------
SERVER_ALLOWED_ORIGINS=https://alatyrhosting.eu

# -------------------------------------------
# GoPay
# -------------------------------------------
GOPAY_ENVIRONMENT=PRODUCTION
GOPAY_CLIENT_ID=
GOPAY_CLIENT_SECRET=
GOPAY_GO_ID=

# -------------------------------------------
# SMTP / e-mail
# -------------------------------------------
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
SMTP_FROM=no-reply@alatyrhosting.eu
# MAIL_FROM=no-reply@alatyrhosting.eu

# -------------------------------------------
# OAuth (Google, GitHub)
# -------------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET

# -------------------------------------------
# Discord notifikace (volitelné)
# -------------------------------------------
# DISCORD_BOT_TOKEN=
# DISCORD_CHANNEL_ID=

# -------------------------------------------
# Frontend build (pouze při npm run build)
# Pro produkční build: VITE_APP_BASE_URL=https://alatyrhosting.eu
# -------------------------------------------
VITE_APP_BASE_URL=https://alatyrhosting.eu
# VITE_API_URL=https://alatyrhosting.eu

# -------------------------------------------
# Logování
# -------------------------------------------
# LOG_LEVEL=info
