# Nginx configuration for Alatyr Hosting (HestiaCP)
# Place this file in: /home/USERNAME/web/DOMAIN/public_html/nginx.conf
# Or add to HestiaCP: Web > Domain > Edit > Advanced > Nginx Directives
#
# IMPORTANT: Replace YOUR_DOMAIN.com and USERNAME with actual values

server {
    listen 80;
    listen [::]:80;
    server_name YOUR_DOMAIN.com www.YOUR_DOMAIN.com;

    # Redirect HTTP to HTTPS
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name YOUR_DOMAIN.com www.YOUR_DOMAIN.com;

    # SSL certificates (HestiaCP manages these)
    ssl_certificate /home/USERNAME/conf/web/ssl/YOUR_DOMAIN.com.crt;
    ssl_certificate_key /home/USERNAME/conf/web/ssl/YOUR_DOMAIN.com.key;

    # SSL configuration (hardened)
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers 'ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384';
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;
    ssl_session_tickets off;

    # OCSP Stapling
    ssl_stapling on;
    ssl_stapling_verify on;
    resolver 1.1.1.1 8.8.8.8 valid=300s;
    resolver_timeout 5s;

    # ============================================
    # Security Headers
    # ============================================
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=()" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;
    add_header Cross-Origin-Opener-Policy "same-origin" always;
    add_header Cross-Origin-Resource-Policy "same-origin" always;

    # Content Security Policy
    add_header Content-Security-Policy "
        default-src 'self';
        img-src 'self' data: https:;
        style-src 'self' 'unsafe-inline';
        script-src 'self';
        font-src 'self' data:;
        connect-src 'self' https://api.gopay.com;
        frame-ancestors 'none';
        base-uri 'self';
        form-action 'self';
        upgrade-insecure-requests;
    " always;

    # Root directory (Vite build)
    root /home/USERNAME/web/YOUR_DOMAIN/public_html/build;
    index index.html;

    # Hide Nginx version
    server_tokens off;

    # Disable directory listing
    autoindex off;

    # ============================================
    # Compression
    # ============================================
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_comp_level 5;
    gzip_proxied any;
    gzip_types
        text/plain
        text/css
        text/xml
        text/javascript
        application/javascript
        application/json
        application/xml
        application/xml+rss
        image/svg+xml
        font/woff2;

    # Brotli (if available - HestiaCP may have brotli module)
    # brotli on;
    # brotli_comp_level 6;
    # brotli_types text/plain text/css text/xml text/javascript application/javascript application/json application/xml image/svg+xml font/woff2;

    # ============================================
    # Rate Limiting (define zones in http block or here)
    # ============================================
    # limit_req_zone $binary_remote_addr zone=api_limit:10m rate=20r/s;
    # limit_req_zone $binary_remote_addr zone=auth_limit:10m rate=5r/m;

    # ============================================
    # API Proxy
    # ============================================
    location /api/ {
        # limit_req zone=api_limit burst=30 nodelay;

        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
        proxy_read_timeout 300s;
        proxy_connect_timeout 75s;
        proxy_send_timeout 300s;

        # Do not cache API responses
        add_header Cache-Control "no-store, no-cache, must-revalidate" always;
    }

    # Stricter rate limit for auth endpoints
    location /api/auth/ {
        # limit_req zone=auth_limit burst=3 nodelay;

        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Health check
    location = /health {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        access_log off;
    }

    # ============================================
    # Static Files with Caching
    # ============================================

    # Vite hashed assets (immutable - safe to cache forever)
    location /assets/ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # Other static assets (images, fonts, etc.)
    location ~* \.(png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|webp|avif)$ {
        expires 30d;
        add_header Cache-Control "public, no-transform";
        access_log off;
    }

    # HTML - never cache (SPA routing)
    location / {
        try_files $uri $uri/ /index.html;

        location = /index.html {
            add_header Cache-Control "no-cache, no-store, must-revalidate";
            add_header Pragma "no-cache";
        }
    }

    # ============================================
    # Security: Block access to sensitive files
    # ============================================

    # Hidden files (.env, .git, .htaccess)
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }

    # Server files, configs, dependencies
    location ~ ^/(node_modules|\.git|\.env|package\.json|package-lock\.json|server\.js|services|middleware|utils|sql|logs) {
        deny all;
        access_log off;
        log_not_found off;
    }

    # Backup and temp files
    location ~ \.(bak|backup|old|orig|save|swp|tmp|~|sql|log)$ {
        deny all;
        access_log off;
        log_not_found off;
    }

    # Directory traversal
    location ~ \.\. {
        deny all;
        access_log off;
        log_not_found off;
    }

    # ============================================
    # Security: Request Filtering
    # ============================================

    # Block dangerous user-agents (scanners)
    if ($http_user_agent ~* (nmap|nikto|wikto|sf|sqlmap|bsqlbf|w3af|acunetix|havij|appscan|dirb|gobuster|masscan|zgrab)) {
        return 403;
    }

    # Block non-standard HTTP methods
    if ($request_method !~ ^(GET|HEAD|POST|PUT|DELETE|OPTIONS|PATCH)$) {
        return 405;
    }

    # ============================================
    # Request Limits
    # ============================================
    client_max_body_size 25M;
    client_body_buffer_size 128k;
    client_body_timeout 60s;
    client_header_timeout 60s;
    send_timeout 60s;

    # Limit header size (prevent header-based attacks)
    large_client_header_buffers 4 16k;
}
